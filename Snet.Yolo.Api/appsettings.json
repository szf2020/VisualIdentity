{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConfigModel": {
    "NameFormat": "yyyyMMddHHmmssffffff",
    "OriginalImageNamingFormat": "{0}-Original.jpeg",
    "ResultImageNamingFormat": "{0}-Result.jpeg",
    "DetailsNamingFormat": "{0}-Details.ini",
    "RetentionDays": 30
  }
}
