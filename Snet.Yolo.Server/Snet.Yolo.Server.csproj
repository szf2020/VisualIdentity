<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net8.0;net9.0</TargetFrameworks>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<Authors>Shun</Authors>
		<Product>Yolo</Product>
		<GenerateDocumentationFile>True</GenerateDocumentationFile>
		<Description>Yolo多模型管理与智能识别服务</Description>
		<PackageProjectUrl>https://shunnet.top</PackageProjectUrl>
		<AuthorsName>Shun</AuthorsName>
		<CompanyName>Snet</CompanyName>
		<PackageIcon>Icon.png</PackageIcon>
		<PackageOutputPath Condition="'$(Configuration)' == 'Release'">../../publish/Release</PackageOutputPath>
		<PackageOutputPath Condition="'$(Configuration)' == 'Debug'">../../publish/Debug</PackageOutputPath>
	</PropertyGroup>

	<ItemGroup>
		<Content Include="Icon.png">
			<PackagePath>
			</PackagePath>
		</Content>
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="SkiaSharp.NativeAssets.Linux" Version="3.119.0" />
		<PackageReference Include="YoloDotNet" Version="3.1.1" />
		<PackageReference Include="Snet.DB" Version="25.234.1" />
	</ItemGroup>

</Project>
