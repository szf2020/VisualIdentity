<UserControl
    x:Class="Snet.Yolo.Tool.View.YoloDataUnificationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:Snet.Yolo.Tool.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:Snet.Yolo.Tool.ViewModel"
    xmlns:snet="https://shunnet.top"
    xmlns:ui="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:uis="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="450"
    d:DesignWidth="800"
    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Yolo.Tool"
    snet:ResxLocalizationProvider.DefaultDictionary="Language"
    mc:Ignorable="d">
    <UserControl.DataContext>
        <model:YoloDataUnificationViewModel />
    </UserControl.DataContext>
    <GroupBox
        Grid.Column="1"
        Margin="5"
        Padding="0"
        ui:ElevationAssist.Elevation="Dp2"
        ui:GroupBoxAssist.HeaderPadding="7"
        Header="{Binding}"
        Style="{StaticResource MaterialDesignCardGroupBox}">
        <GroupBox.HeaderTemplate>
            <DataTemplate>
                <StackPanel
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Image
                        Width="15"
                        Height="15"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Source="{DynamicResource Config}"
                        Stretch="Fill" />
                    <TextBlock
                        Margin="5,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="{snet:Loc 标注数据处理}"
                        TextAlignment="Center" />
                </StackPanel>
            </DataTemplate>
        </GroupBox.HeaderTemplate>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Button
                Grid.Column="1"
                Margin="0,-32,0,0"
                Padding="10,0,10,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                ui:ButtonAssist.CornerRadius="0,4,0,0"
                Command="{Binding Handle}"
                Style="{StaticResource MaterialDesignFlatSecondaryButton}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Image
                            Width="15"
                            Height="15"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Source="{DynamicResource AutoHandler}"
                            Stretch="Fill" />
                    </Grid>
                    <Grid Grid.Column="2">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="{snet:Loc 处理}"
                            TextAlignment="Center" />
                    </Grid>
                </Grid>
            </Button>

            <Border BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}" BorderThickness="0,0,0,1">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <snet:TextBoxControl
                        Grid.Column="0"
                        Hint="{snet:Loc 图片文件夹名称}"
                        Icon="{DynamicResource GroupName}"
                        Text="{Binding ImageFolderName}" />
                    <snet:TextBoxControl
                        Grid.Column="1"
                        Margin="5,0,0,0"
                        Hint="{snet:Loc 标签文件夹名称}"
                        Icon="{DynamicResource GroupName}"
                        Text="{Binding LabelFolderName}" />
                    <snet:TextBoxControl
                        Grid.Column="2"
                        Margin="5,0,0,0"
                        Hint="{snet:Loc 存储路径}"
                        Icon="{DynamicResource Path}"
                        Text="{Binding SavePath}" />
                    <snet:ButtonControl
                        Grid.Column="3"
                        Margin="5,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        BorderThickness="0,0,0,0"
                        Command="{Binding SelectSavePath}"
                        Content="{snet:Loc 选择存储路径}"
                        Icon="{DynamicResource Select}" />
                </Grid>
            </Border>


            <!--  插件列表  -->
            <DataGrid
                Grid.Row="1"
                Margin="5"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                ColumnHeaderHeight="45"
                GridLinesVisibility="None"
                IsReadOnly="True"
                ItemsSource="{Binding DataGridItemsSource}"
                SelectedItem="{Binding DataGridSelectedItem}"
                SelectionMode="Single"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">

                <i:Interaction.Triggers>
                    <!--  内容菜单打开  -->
                    <i:EventTrigger EventName="ContextMenuOpening">
                        <snet:EventCommand Command="{Binding DataGrid_ContextMenuOpening}" />
                    </i:EventTrigger>
                    <!--  右键按下  -->
                    <i:EventTrigger EventName="PreviewMouseRightButtonDown">
                        <snet:EventCommand Command="{Binding DataGrid_PreviewMouseRightButtonDown}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <DataGrid.Resources>

                    <!--  滚动条样式  -->
                    <Style BasedOn="{StaticResource UiScrollBar}" TargetType="ScrollBar" />

                    <!--  Header样式  -->
                    <Style
                        x:Key="DataGridColumnHeaderStyle"
                        BasedOn="{StaticResource DefaultDataGridColumnHeaderStyle}"
                        TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                    </Style>

                    <!--  单元格内容居中样式  -->
                    <Style
                        x:Key="DataGridCellStyle"
                        BasedOn="{StaticResource DefaultDataGridCellStyle}"
                        TargetType="{x:Type DataGridCell}">
                        <Setter Property="Height" Value="45" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>

                </DataGrid.Resources>
                <!--  右键菜单  -->
                <DataGrid.ContextMenu>
                    <ContextMenu VerticalContentAlignment="Center">
                        <ContextMenu.Style>
                            <Style BasedOn="{StaticResource UiContextMenu}" TargetType="{x:Type ContextMenu}" />
                        </ContextMenu.Style>
                        <uis:MenuItem
                            snet:ResxLocalizationProvider.DefaultAssembly="Snet.Yolo.Tool"
                            snet:ResxLocalizationProvider.DefaultDictionary="Language"
                            Command="{Binding AddItem}"
                            Header="{snet:Loc 添加项}"
                            Icon="{uis:SymbolIcon Symbol=Add24,
                                                  Filled=False}" />
                        <uis:MenuItem
                            snet:ResxLocalizationProvider.DefaultAssembly="Snet.Yolo.Tool"
                            snet:ResxLocalizationProvider.DefaultDictionary="Language"
                            Command="{Binding UpdateItem}"
                            Header="{snet:Loc 修改项}"
                            Icon="{uis:SymbolIcon Symbol=ItemCompare24,
                                                  Filled=False}">
                            <uis:MenuItem.Style>
                                <Style BasedOn="{StaticResource UiMenuItem}" TargetType="uis:MenuItem">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.DataGridSelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </uis:MenuItem.Style>
                        </uis:MenuItem>
                        <uis:MenuItem
                            snet:ResxLocalizationProvider.DefaultAssembly="Snet.Yolo.Tool"
                            snet:ResxLocalizationProvider.DefaultDictionary="Language"
                            Command="{Binding RemoveItem}"
                            Header="{snet:Loc 移除项}"
                            Icon="{uis:SymbolIcon Symbol=TrayItemRemove20,
                                                  Filled=False}">
                            <uis:MenuItem.Style>
                                <Style BasedOn="{StaticResource UiMenuItem}" TargetType="uis:MenuItem">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.DataGridSelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </uis:MenuItem.Style>
                        </uis:MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>



                <DataGrid.Columns>
                    <DataGridTextColumn
                        snet:ResxLocalizationProvider.DefaultAssembly="Snet.Yolo.Tool"
                        snet:ResxLocalizationProvider.DefaultDictionary="Language"
                        Binding="{Binding Index}"
                        CellStyle="{StaticResource DataGridCellStyle}"
                        HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                        <DataGridTextColumn.Header>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Image
                                    Width="13"
                                    Height="13"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Source="{DynamicResource Channel}"
                                    Stretch="Fill" />
                                <TextBlock
                                    Margin="5,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{snet:Loc 下标}"
                                    TextAlignment="Center" />
                            </StackPanel>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        snet:ResxLocalizationProvider.DefaultAssembly="Snet.Yolo.Tool"
                        snet:ResxLocalizationProvider.DefaultDictionary="Language"
                        Binding="{Binding Name}"
                        CellStyle="{StaticResource DataGridCellStyle}"
                        HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                        <DataGridTextColumn.Header>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Image
                                    Width="13"
                                    Height="13"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Source="{DynamicResource GroupName}"
                                    Stretch="Fill" />
                                <TextBlock
                                    Margin="5,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{snet:Loc 名称}"
                                    TextAlignment="Center" />
                            </StackPanel>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="*"
                        snet:ResxLocalizationProvider.DefaultAssembly="Snet.Yolo.Tool"
                        snet:ResxLocalizationProvider.DefaultDictionary="Language"
                        Binding="{Binding Describe}"
                        CellStyle="{StaticResource DataGridCellStyle}"
                        HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                        <DataGridTextColumn.Header>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Image
                                    Width="13"
                                    Height="13"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Source="{DynamicResource Info}"
                                    Stretch="Fill" />
                                <TextBlock
                                    Margin="5,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{snet:Loc 描述}"
                                    TextAlignment="Center" />
                            </StackPanel>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn
                        Width="300"
                        snet:ResxLocalizationProvider.DefaultAssembly="Snet.Yolo.Tool"
                        snet:ResxLocalizationProvider.DefaultDictionary="Language"
                        CellStyle="{StaticResource DataGridCellStyle}"
                        HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                        <DataGridTemplateColumn.Header>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Image
                                    Width="13"
                                    Height="13"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Source="{DynamicResource Operate}"
                                    Stretch="Fill" />
                                <TextBlock
                                    Margin="5,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{snet:Loc 操作}"
                                    TextAlignment="Center" />
                            </StackPanel>
                        </DataGridTemplateColumn.Header>

                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <snet:ButtonControl
                                    Margin="5,0,0,0"
                                    Command="{Binding SelectPath}"
                                    Content="{snet:Loc 选择父路径}"
                                    Icon="{DynamicResource Select}"
                                    ToolTip="{Binding Path}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </GroupBox>
</UserControl>
